{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "signals.schema.json",
  "title": "UserSignals",
  "type": "object",
  "required": [
    "intent",
    "constraints",
    "objections",
    "trust_flags",
    "ambiguity",
    "conflicts",
    "engagement",
    "confidence"
  ],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["explore", "compare", "buy", "defer", "reject", "unknown"]
    },
    "constraints": {
      "type": "object",
      "required": ["budget_tier", "priority", "use_case", "device"],
      "properties": {
        "budget_tier": { "type": "string", "enum": ["unknown", "budget", "mid", "premium"] },
        "priority": { "type": "string", "enum": ["unknown", "anc", "calls", "fit", "battery", "value", "sound", "reliability"] },
        "use_case": { "type": "string", "enum": ["unknown", "commute", "calls", "gym", "running", "music", "work", "casual"] },
        "device": { "type": "string", "enum": ["unknown", "ios", "android"] }
      },
      "additionalProperties": false
    },
    "objections": {
      "type": "array",
      "items": { "type": "string", "enum": ["price", "authenticity", "time", "returns", "brand_loyalty"] }
    },
    "trust_flags": {
      "type": "array",
      "items": { "type": "string", "enum": ["authenticity", "warranty", "returns"] }
    },
    "ambiguity": {
      "type": "object",
      "required": ["is_ambiguous", "reason"],
      "properties": {
        "is_ambiguous": { "type": "boolean" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "conflicts": {
      "type": "array",
      "items": { "type": "string", "enum": ["price_vs_quality", "feature_vs_budget"] }
    },
    "engagement": { "type": "string", "enum": ["low", "medium", "high"] },
    "confidence": {
      "type": "object",
      "required": ["overall"],
      "properties": {
        "overall": { "type": "number", "minimum": 0, "maximum": 1 },
        "constraint_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
